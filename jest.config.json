{
  "moduleFileExtensions": [
    "ts",
    "js"
  ],
  "rootDir": "./test",
  "testEnvironment": "node",
  "verbose": true,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "setupFiles": [
    "dotenv/config"
  ],
  "setupFilesAfterEnv": [
    "../jest.env.ts"
  ]
}