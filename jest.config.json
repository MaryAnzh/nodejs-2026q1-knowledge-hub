{
  "moduleFileExtensions": [
    "ts",
    "js"
  ],
  "rootDir": "./",
  "testEnvironment": "node",
  "verbose": true,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "setupFiles": [
    "dotenv/config"
  ],
  "setupFilesAfterEnv": [
    "<rootDir>/jest.env.ts"
  ]
}